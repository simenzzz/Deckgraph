{
  "name": "deckgraph-vscode",
  "version": "0.0.1",
  "private": true,
  "description": "Deckgraph - VS Code extension for dependency exploration",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onCommand:deckgraph.start",
    "onView:deckgraph.moduleTree"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deckgraph",
          "title": "Deckgraph",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "deckgraph": [
        {
          "id": "deckgraph.moduleTree",
          "name": "Modules"
        },
        {
          "id": "deckgraph.dashboard",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "deckgraph.start",
        "title": "Deckgraph: Start"
      },
      {
        "command": "deckgraph.scan",
        "title": "Deckgraph: Scan Project"
      },
      {
        "command": "deckgraph.showDashboard",
        "title": "Deckgraph: Show Dashboard"
      },
      {
        "command": "deckgraph.openModule",
        "title": "Deckgraph: Open Module"
      }
    ]
  },
  "dependencies": {
    "@deckgraph/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.14",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
